#### *Pattern 1 – Right Triangle*

for i in range(1, 6):
    print("*" * i)



#### *Pattern 2 – Number Pattern*

for i in range(1, 6):
    for j in range(1, i+1):
        print(j, end=" ")
    print()



    #### *Pattern 3 – Pyramid*

rows = 5
for i in range(rows):
    print(" " * (rows-i-1) + "* " * (i+1))
